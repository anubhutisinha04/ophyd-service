  "standalone_pv_alternatives": {
    "_note": "If you want to register a PV WITHOUT a device wrapper (lighter; no lock semantics, just label-based grouping), POST one of these to /api/v1/pvs instead of /api/v1/devices. A PV cannot be both device-bound AND standalone — pick one.",

    "random_walk_x": {
      "pv_name": "random_walk:x",
      "description": "Random-walk value",
      "protocol": "ca",
      "access_mode": "read-write",
      "labels": ["random_walk", "diagnostic"]
    },
    "thermo_I": {
      "pv_name": "thermo:I",
      "description": "Thermo simulation readback",
      "protocol": "ca",
      "access_mode": "read-only",
      "labels": ["temperature", "diagnostic"]
    }
  },

  "update_examples": {
    "_note": "PUT /api/v1/devices/{name} accepts partial bodies — only included fields change.",

    "add_documentation_and_labels": {
      "metadata": {
        "documentation": "Updated description here.",
        "labels": ["temperature", "sim", "demo"]
      }
    },
    "deactivate_via_spec": {
      "instantiation_spec": {"active": false}
    },
    "rename_pv_mapping": {
      "metadata": {
        "pvs": {
          "readback": "thermo:I",
          "setpoint": "thermo:SP"
        }
      }
    }
  }
