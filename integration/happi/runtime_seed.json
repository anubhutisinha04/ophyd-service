        "is_configurable": true,
        "is_checkable": true,
        "is_subscribable": true,
        "pvs": {
          "user_setpoint": "sim:mtr2",
          "user_readback": "sim:mtr2.RBV",
          "velocity":      "sim:mtr2.VELO",
          "acceleration":  "sim:mtr2.ACCL",
          "motor_done_move": "sim:mtr2.DMOV",
          "motor_stop":      "sim:mtr2.STOP",
          "high_limit_travel": "sim:mtr2.HLM",
          "low_limit_travel":  "sim:mtr2.LLM"
        },
        "labels": ["motors", "sim"],
        "documentation": "Fake motor #2 — velocity 2, limits -10 to 20, precision 2."
      },
      "instantiation_spec": {
        "name": "motor2",
        "device_class": "ophyd.EpicsMotor",
        "args": ["sim:mtr2"],
        "kwargs": {"name": "motor2"},
        "active": true
      }
    },

    "motor3": {
      "metadata": {
        "name": "motor3",
        "device_label": "motor",
        "ophyd_class": "EpicsMotor",
        "module": "ophyd.epics_motor",
