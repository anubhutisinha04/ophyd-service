{
  "_README": {
    "purpose": "Reference catalog of runtime device/PV CRUD bodies for the pods/full compose. NOT loaded by configuration_service — happi_db.json is the only file the loader reads.",
    "usage": "Copy any inner object into Swagger UI at http://localhost:8004/docs and POST it to /api/v1/devices (compounds + leaf signals) or /api/v1/pvs (standalone PVs).",
    "endpoints": {
      "create_device":      "POST   /api/v1/devices",
      "read_device":        "GET    /api/v1/devices/{name}",
      "read_device_pvs":    "GET    /api/v1/devices/{name}/pvs",
      "read_device_spec":   "GET    /api/v1/devices/{name}/instantiation",
      "update_device":      "PUT    /api/v1/devices/{name}",
      "enable_device":      "PATCH  /api/v1/devices/{name}/enable",
      "disable_device":     "PATCH  /api/v1/devices/{name}/disable",
      "delete_device":      "DELETE /api/v1/devices/{name}",
      "create_standalone":  "POST   /api/v1/pvs",
      "list_standalone":    "GET    /api/v1/pvs/standalone",
      "update_standalone":  "PUT    /api/v1/pvs/standalone/{pv_name}",
      "delete_standalone":  "DELETE /api/v1/pvs/standalone/{pv_name}"
    },
    "ioc_inventory": {
      "ioc_random_walk":   {"prefix": "random_walk:",       "pvs": ["random_walk:dt", "random_walk:x"]},
      "ioc_random_walk_h": {"prefix": "random_walk:horiz-", "pvs": ["random_walk:horiz-dt", "random_walk:horiz-x"]},
      "ioc_random_walk_v": {"prefix": "random_walk:vert-",  "pvs": ["random_walk:vert-dt", "random_walk:vert-x"]},
      "ioc_thermo":        {"prefix": "thermo:",            "pvs": ["thermo:I (RO)", "thermo:SP", "thermo:K", "thermo:omega", "thermo:Tvar"]},
      "ioc_fake_motor":    {"prefix": "sim:",               "pvs": ["sim:mtr1 (motor record: .VAL .RBV .VELO .ACCL .STOP .DMOV .HLM .LLM ...)", "sim:mtr2", "sim:mtr3"]}
    },
    "notes": [
      "metadata.name and instantiation_spec.name MUST match (server returns 400 otherwise).",
      "device_label enum: motor | detector | signal | flyer | readable | device.",
      "pvs map is verbatim — runtime CRUD does NOT auto-derive component->PV mapping.",
      "localdevs.RandomWalk / localdevs.Thermo import paths are stored as text; configuration_service does not import them. direct_control reads PVs by name."
    ]
  },

  "compound_devices": {

    "random_walk": {
      "metadata": {
        "name": "random_walk",
        "device_label": "device",
        "ophyd_class": "RandomWalk",
        "module": "localdevs",
        "is_readable": true,
        "is_subscribable": true,
        "pvs": {
          "dt": "random_walk:dt",
          "x":  "random_walk:x"
        },
        "labels": ["random_walk"],
        "documentation": "random_walk IOC at random_walk: — components: dt (config), x (hinted)."
      },
      "instantiation_spec": {
        "name": "random_walk",
        "device_class": "localdevs.RandomWalk",
        "args": ["random_walk:"],
        "kwargs": {"name": "random_walk"},
        "active": true
      }
    },

    "random_walk_h": {
      "metadata": {
        "name": "random_walk_h",
        "device_label": "device",
        "ophyd_class": "RandomWalk",
        "module": "localdevs",
        "is_readable": true,
        "is_subscribable": true,
        "pvs": {
          "dt": "random_walk:horiz-dt",
          "x":  "random_walk:horiz-x"
        },
        "labels": ["random_walk", "horizontal"],
        "documentation": "Horizontal random walk (random_walk:horiz- prefix)."
      },
      "instantiation_spec": {
        "name": "random_walk_h",
        "device_class": "localdevs.RandomWalk",
        "args": ["random_walk:horiz-"],
        "kwargs": {"name": "random_walk_h"},
        "active": true
      }
    },

    "random_walk_v": {
      "metadata": {
        "name": "random_walk_v",
        "device_label": "device",
        "ophyd_class": "RandomWalk",
        "module": "localdevs",
        "is_readable": true,
        "is_subscribable": true,
        "pvs": {
          "dt": "random_walk:vert-dt",
          "x":  "random_walk:vert-x"
        },
        "labels": ["random_walk", "vertical"],
        "documentation": "Vertical random walk (random_walk:vert- prefix)."
      },
      "instantiation_spec": {
        "name": "random_walk_v",
        "device_class": "localdevs.RandomWalk",
        "args": ["random_walk:vert-"],
        "kwargs": {"name": "random_walk_v"},
        "active": true
      }
    },

    "thermo": {
      "metadata": {
        "name": "thermo",
        "device_label": "device",
        "ophyd_class": "Thermo",
        "module": "localdevs",
        "is_readable": true,
        "is_movable": true,
        "is_stoppable": true,
        "is_subscribable": true,
        "pvs": {
          "readback": "thermo:I",
          "setpoint": "thermo:SP",
          "K":        "thermo:K",
          "omega":    "thermo:omega",
          "Tvar":     "thermo:Tvar"
        },
        "labels": ["temperature"],
        "documentation": "Eurotherm-shape thermo_sim IOC at thermo: — readback I (RO), setpoint SP, plus K/omega/Tvar config."
      },
      "instantiation_spec": {
        "name": "thermo",
        "device_class": "localdevs.Thermo",
        "args": ["thermo:"],
        "kwargs": {"name": "thermo"},
        "active": true
      }
    }
  },

  "epics_motors": {
    "_note": "Real motor records from caproto.ioc_examples.fake_motor_record (sim:mtr1/2/3). Unlike mini_beamline's bare-float 'motors', these expose the full motor record (.VAL/.RBV/.VELO/.ACCL/.STOP/.DMOV/.HLM/.LLM/...) and can be wrapped with ophyd.EpicsMotor for the full Movable/Stoppable/Stageable/Configurable/Checkable/Subscribable interface.",

    "motor1": {
      "metadata": {
        "name": "motor1",
        "device_label": "motor",
        "ophyd_class": "EpicsMotor",
        "module": "ophyd.epics_motor",
        "is_movable": true,
        "is_readable": true,
        "is_stoppable": true,
        "is_stageable": true,
        "is_configurable": true,
        "is_checkable": true,
        "is_subscribable": true,
        "pvs": {
          "user_setpoint": "sim:mtr1",
          "user_readback": "sim:mtr1.RBV",
          "velocity":      "sim:mtr1.VELO",
          "acceleration":  "sim:mtr1.ACCL",
          "motor_done_move": "sim:mtr1.DMOV",
          "motor_stop":      "sim:mtr1.STOP",
          "high_limit_travel": "sim:mtr1.HLM",
          "low_limit_travel":  "sim:mtr1.LLM"
        },
        "labels": ["motors", "sim"],
        "documentation": "Fake motor #1 — velocity 1, limits 0-10, precision 3."
      },
      "instantiation_spec": {
        "name": "motor1",
        "device_class": "ophyd.EpicsMotor",
        "args": ["sim:mtr1"],
        "kwargs": {"name": "motor1"},
        "active": true
      }
    },

    "motor2": {
      "metadata": {
        "name": "motor2",
        "device_label": "motor",
        "ophyd_class": "EpicsMotor",
        "module": "ophyd.epics_motor",
        "is_movable": true,
        "is_readable": true,
        "is_stoppable": true,
