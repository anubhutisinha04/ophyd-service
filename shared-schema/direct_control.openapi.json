{
  "openapi": "3.1.0",
  "info": {
    "title": "Bluesky Direct Device Control + Monitoring",
    "description": "Device commanding with A4 coordination checks, plus real-time EPICS PV monitoring via WebSocket.",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Combined health check: coordination availability and monitoring stats.\n\nReturns 503 when configuration_service is unreachable so LB readiness\nprobes can route away. ``coordination_service_detail`` carries the\nstructured reason (timeout / connect-refused / non-2xx).",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stats": {
      "get": {
        "summary": "Get Stats",
        "operationId": "get_stats_api_v1_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/pv/set": {
      "post": {
        "summary": "Set Pv",
        "description": "Set EPICS PV value with coordination check (Low Fidelity Channel).\n\nTwo modes:\n- wait=False (fire-and-forget, default): Issues write, returns immediately.\n- wait=True (put-completion): Waits for EPICS put-completion callback.\n\nRaises 404 if PV not in registry, 423 if device locked, 503 if\ncoordination service unavailable.",
        "operationId": "set_pv_api_v1_pv_set_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PVSetRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PVSetResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/pv/{pv_name}/value": {
      "get": {
        "summary": "Get Pv Value From Controller",
        "description": "One-shot CA get via DeviceController (no subscription).\n\nExposes the pyepics caget / ca.get knobs as query params. Returns a\ntiled-style envelope: JSON by default with `shape`/`dtype`/`ndim`/\n`nbytes` alongside the value; `Accept: application/octet-stream` (or\n`?format=binary`) returns raw bytes with the same metadata in\n`X-PV-*` headers.",
        "operationId": "get_pv_value_from_controller_api_v1_pv__pv_name__value_get",
        "parameters": [
          {
            "name": "pv_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Pv Name"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Override Accept header. 'json' or 'binary' (octet-stream).",
              "title": "Format"
            },
            "description": "Override Accept header. 'json' or 'binary' (octet-stream)."
          },
          {
            "name": "as_string",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Return the string representation (e.g. enum label)",
              "default": false,
              "title": "As String"
            },
            "description": "Return the string representation (e.g. enum label)"
          },
          {
            "name": "count",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Max waveform elements to return",
              "title": "Count"
            },
            "description": "Max waveform elements to return"
          },
          {
            "name": "as_numpy",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Return arrays as numpy.ndarray (JSON-serialized to list)",
              "default": true,
              "title": "As Numpy"
            },
            "description": "Return arrays as numpy.ndarray (JSON-serialized to list)"
          },
          {
            "name": "use_monitor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Use cached monitor value. Default false matches the one-shot semantics of this endpoint; set true to share a monitor with any existing subscription (note: pyepics auto-installs a permanent CA monitor the first time this is true for a PV).",
              "default": false,
              "title": "Use Monitor"
            },
            "description": "Use cached monitor value. Default false matches the one-shot semantics of this endpoint; set true to share a monitor with any existing subscription (note: pyepics auto-installs a permanent CA monitor the first time this is true for a PV)."
          },
          {
            "name": "timeout",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "CA get timeout in seconds",
              "default": 5.0,
              "title": "Timeout"
            },
            "description": "CA get timeout in seconds"
          },
          {
            "name": "connection_timeout",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "CA connection timeout in seconds",
              "default": 5.0,
              "title": "Connection Timeout"
            },
            "description": "CA connection timeout in seconds"
          },
          {
            "name": "ftype",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Force non-native DBR type (power user)",
              "title": "Ftype"
            },
            "description": "Force non-native DBR type (power user)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/pvs/{pv_name}/value": {
      "get": {
        "summary": "Get Monitored Pv Value",
