  "components": {
    "schemas": {
      "CommandMode": {
        "type": "string",
        "enum": [
          "put-completion",
          "fire-and-forget"
        ],
        "title": "CommandMode",
        "description": "Command execution mode for PV writes."
      },
      "DeviceCommandRequest": {
        "properties": {
          "device_name": {
            "type": "string",
            "title": "Device Name"
          },
          "method": {
            "type": "string",
            "title": "Method"
          },
          "args": {
            "items": {},
            "type": "array",
            "title": "Args"
          },
          "kwargs": {
            "additionalProperties": true,
            "type": "object",
            "title": "Kwargs"
          },
          "timeout": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Timeout"
          },
          "use_put": {
            "type": "boolean",
            "title": "Use Put",
            "default": false
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "device_name",
          "method"
        ],
        "title": "DeviceCommandRequest",
        "description": "Request to execute a device method (High Fidelity Channel).\n\nuse_put=False (default): ophyd set() waits for completion.\nuse_put=True: ophyd put() returns immediately."
      },
      "DeviceCommandResponse": {
        "properties": {
          "device_name": {
            "type": "string",
            "title": "Device Name"
          },
          "method": {
            "type": "string",
            "title": "Method"
          },
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "result": {
            "title": "Result"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "coordination_checked": {
            "type": "boolean",
            "title": "Coordination Checked"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          },
          "use_put": {
            "type": "boolean",
            "title": "Use Put",
            "default": false
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "device_name",
          "method",
          "success",
          "timestamp",
          "coordination_checked"
        ],
        "title": "DeviceCommandResponse",
        "description": "Response from device command execution."
      },
      "EnrichmentRequest": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/EnrichmentSpec"
            },
            "type": "array",
            "maxItems": 200,
            "minItems": 1,
            "title": "Items",
            "description": "Specs to enrich, in caller order. Results match by index."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "items"
        ],
        "title": "EnrichmentRequest",
        "description": "Batch enrichment request from configuration_service."
      },
      "EnrichmentResponse": {
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/EnrichmentResultItem"
            },
            "type": "array",
            "title": "Results"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "results"
        ],
        "title": "EnrichmentResponse",
        "description": "Aggregate enrichment response.\n\nPer-item results in caller order. Resolution is read-only and never\nhalts \u2014 one bad item doesn't fail the others."
      },
      "EnrichmentResultItem": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "pv_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pv Name"
          },
          "error_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Type",
            "description": "Short tag identifying the failure category when ok=false."
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "ok"
        ],
        "title": "EnrichmentResultItem",
        "description": "Per-item enrichment outcome.\n\nResults are returned in the same order as the request items so the\ncaller (configuration_service) can correlate by index \u2014 no\npassthrough identifier needed."
      },
      "EnrichmentSpec": {
        "properties": {
          "device_class_path": {
            "type": "string",
            "title": "Device Class Path",
            "description": "Fully qualified import path of the device class."
          },
          "prefix": {
            "type": "string",
            "title": "Prefix",
            "description": "EPICS prefix the device is constructed with."
          },
          "sub_path": {
            "type": "string",
            "title": "Sub Path",
            "description": "Dotted attribute chain to walk on the instantiated device. Empty string means the device IS the leaf signal."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "device_class_path",
          "prefix",
          "sub_path"
        ],
        "title": "EnrichmentSpec",
        "description": "One device-class + sub-path to enrich.\n\nSent by configuration_service to direct_control when the\nconfiguration_service-side static resolver returns\n``needs_enrichment`` (typically an ophyd ``FormattedComponent`` with\nruntime placeholders like ``{self.parent.prefix}``). Direct-control\ninstantiates the device class once via its ophyd-cache, walks the\nsub-path with ``operator.attrgetter``, and reports the underlying PV.\n\n``sub_path`` is the dotted chain *after* the device name (since\ndirect-control has no registry of its own). For an address like\n``m1a.pit.actuate``, the head segment ``m1a`` is consumed by\nconfiguration_service for the device lookup; direct-control receives\n``sub_path=\"pit.actuate\"`` plus the class path and prefix."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "unhealthy"
            ],
            "title": "Status",
            "default": "healthy"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "coordination_service_available": {
            "type": "boolean",
            "title": "Coordination Service Available"
          },
          "coordination_service_detail": {
