            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Override Accept header. 'json' or 'binary' (octet-stream).",
              "title": "Format"
            },
            "description": "Override Accept header. 'json' or 'binary' (octet-stream)."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
