                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Timeout",
            "description": "Put timeout in seconds (used with wait=True or use_complete=True)"
          },
          "connection_timeout": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Connection Timeout",
            "description": "Max seconds to wait for CA connection (pyepics default 5s)"
          },
          "use_complete": {
            "type": "boolean",
            "title": "Use Complete",
            "description": "If True, wait for put via pyepics put-callback instead of blocking a CA thread. Overrides `wait` (always waits) but frees the worker.",
            "default": false
          },
          "ftype": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ftype",
            "description": "Force non-native DBR type (power-user knob; leave null for native)"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "pv_name",
          "value"
        ],
        "title": "PVSetRequest",
        "description": "Request to set a PV value (Low Fidelity Channel).\n\nCompletion modes:\n- wait=False, use_complete=False (default): fire-and-forget \u2014 issue write, return.\n- wait=True,  use_complete=False: block a CA thread until put finishes.\n- use_complete=True: put-with-callback \u2014 CA thread is freed; service polls\n  for completion via the pyepics put-callback mechanism. Preferred for\n  long puts over HTTP because no worker thread is held.\n\n`connection_timeout` bounds how long we wait to establish CA connection;\nseparate from `timeout` which bounds the put itself.\n\n`ftype` forces a non-native DBR type on the wire (rare, e.g. when an IOC\nexpects CHAR waveforms represented differently). Leave None for native."
      },
