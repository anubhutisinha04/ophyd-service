    "/api/v1/device/{device_path}": {
      "post": {
        "summary": "Access Nested Device",
        "description": "Access nested device component (e.g. motor1.user_readback).\n\nReads are always allowed; write methods are coordination-checked and\nrejected with 403 in read-only mode. 404/423/503/500 on failure modes.",
        "operationId": "access_nested_device_api_v1_device__device_path__post",
        "parameters": [
          {
            "name": "device_path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Device Path"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/NestedDeviceRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Request"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestedDeviceResponse"
                }
