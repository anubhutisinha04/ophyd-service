  "components": {
    "schemas": {
      "CommandMode": {
        "type": "string",
        "enum": [
          "put-completion",
          "fire-and-forget"
        ],
        "title": "CommandMode",
        "description": "Command execution mode for PV writes."
      },
      "DeviceCommandRequest": {
        "properties": {
          "device_name": {
            "type": "string",
            "title": "Device Name"
          },
          "method": {
            "type": "string",
            "title": "Method"
          },
          "args": {
            "items": {},
            "type": "array",
            "title": "Args"
          },
          "kwargs": {
            "additionalProperties": true,
            "type": "object",
            "title": "Kwargs"
          },
          "timeout": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Timeout"
          },
          "use_put": {
            "type": "boolean",
            "title": "Use Put",
            "default": false
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "device_name",
          "method"
        ],
        "title": "DeviceCommandRequest",
        "description": "Request to execute a device method (High Fidelity Channel).\n\nuse_put=False (default): ophyd set() waits for completion.\nuse_put=True: ophyd put() returns immediately."
      },
      "DeviceCommandResponse": {
        "properties": {
          "device_name": {
            "type": "string",
            "title": "Device Name"
          },
          "method": {
            "type": "string",
            "title": "Method"
          },
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "result": {
            "title": "Result"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "coordination_checked": {
            "type": "boolean",
            "title": "Coordination Checked"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          },
          "use_put": {
            "type": "boolean",
            "title": "Use Put",
            "default": false
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "device_name",
          "method",
          "success",
          "timestamp",
          "coordination_checked"
        ],
        "title": "DeviceCommandResponse",
        "description": "Response from device command execution."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "unhealthy"
            ],
            "title": "Status",
            "default": "healthy"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "coordination_service_available": {
            "type": "boolean",
            "title": "Coordination Service Available"
          },
          "coordination_service_detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Coordination Service Detail"
          },
          "active_subscriptions": {
            "type": "integer",
            "title": "Active Subscriptions",
            "default": 0
          },
          "connected_pvs": {
            "type": "integer",
            "title": "Connected Pvs",
            "default": 0
          },
          "websocket_connections": {
            "type": "integer",
            "title": "Websocket Connections",
            "default": 0
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "timestamp",
          "coordination_service_available"
        ],
        "title": "HealthResponse",
        "description": "Health check response for the merged service."
      },
      "NestedDeviceRequest": {
        "properties": {
          "method": {
            "type": "string",
            "title": "Method",
            "default": "read"
          },
          "value": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Value"
          },
          "timeout": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timeout"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "NestedDeviceRequest",
        "description": "Request to access nested device component."
      },
      "NestedDeviceResponse": {
        "properties": {
          "device_path": {
            "type": "string",
            "title": "Device Path"
          },
          "method": {
            "type": "string",
            "title": "Method"
          },
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "result": {
            "title": "Result"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "device_path",
          "method",
          "success",
          "timestamp"
        ],
        "title": "NestedDeviceResponse",
        "description": "Response from nested device access."
      },
      "PVSetRequest": {
        "properties": {
          "pv_name": {
            "type": "string",
            "title": "Pv Name",
            "description": "EPICS PV name"
          },
          "value": {
            "title": "Value",
            "description": "Value to set"
          },
          "wait": {
            "type": "boolean",
            "title": "Wait",
            "description": "Block the CA thread until put completion",
            "default": false
          },
          "timeout": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Timeout",
            "description": "Put timeout in seconds (used with wait=True or use_complete=True)"
          },
          "connection_timeout": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Connection Timeout",
            "description": "Max seconds to wait for CA connection (pyepics default 5s)"
          },
          "use_complete": {
            "type": "boolean",
            "title": "Use Complete",
            "description": "If True, wait for put via pyepics put-callback instead of blocking a CA thread. Overrides `wait` (always waits) but frees the worker.",
