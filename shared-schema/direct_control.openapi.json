    "/api/v1/device/execute": {
      "post": {
        "summary": "Execute Device Method",
        "description": "Execute an ophyd / ophyd-async device method with coordination check\n(High Fidelity Channel).\n\nThe device is instantiated live from its registry instantiation spec;\nStatus completion is awaited unless ``use_put=true``. Raises\n400 (method not allowed) / 404 (device not in registry) /\n409/423 (disabled/locked) / 422 (no instantiation spec) /\n503 (registry or coordination unavailable) / 500 (execution failure).",
        "operationId": "execute_device_method_api_v1_device_execute_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceCommandRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceCommandResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/device/{device_name}/stop": {
      "post": {
        "summary": "Stop Device",
