                  "type": "array",
                  "title": "Response Get Connected Pvs Api V1 Pvs Connected Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/device/execute": {
      "post": {
        "summary": "Execute Device Method",
        "description": "Execute Ophyd device method with coordination check (High Fidelity Channel).\n\nAlways returns a confirmed result. Use when confirmation is required.\nRaises 404/423/503/500 on various failure modes.",
